# ─────────────────────────────────────────────────────────────
# Klarvo — variables de entorno (copia a .env.local y rellena)
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Klarvo

# Supabase (Postgres + Auth + Storage) — región UE
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (pagos, depósitos y suscripciones)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Application fee (%) sobre depósitos vía Stripe Connect
STRIPE_APPLICATION_FEE_PERCENT=1

# Email transaccional (Resend)
RESEND_API_KEY=
EMAIL_FROM="Klarvo <hola@klarvo.es>"

# Cron (protege /api/cron/*). Genera un secreto aleatorio largo.
CRON_SECRET=

# VeriFactu (Fase 2 — proveedor certificado AEAT)
VERIFACTU_PROVIDER_API_KEY=
VERIFACTU_ENABLED=false
